# Copy this file to .env and fill in the values.
# .env is gitignored — NEVER commit secrets.

# --- Solana ---
# RPC endpoint (devnet by default). Switch to mainnet-beta only when intended.
RPC_URL=https://api.devnet.solana.com
# Websocket URL (leave blank to derive from RPC_URL).
WS_URL=
# Deployed escrow program id.
PROGRAM_ID=CPZx26QXs3HjwGobr8cVAZEtF1qGzqnNbBdt7h1EwbBg
# Scorer keypair: pick ONE of the two below.
#   - SCORER_KEYPAIR_PATH: file path. Best for local dev (Solana CLI default).
#   - SCORER_KEYPAIR_JSON: the JSON array contents inline as a string. Best for
#     cloud (Railway/Fly), where mounting files is harder than setting an env var.
SCORER_KEYPAIR_PATH=~/.config/solana/ghbounty-dev.json
# SCORER_KEYPAIR_JSON=[12, 34, 56, ..., 78]   # 64-byte array
# Score (0..10) assigned by the stub when no ANTHROPIC_API_KEY is set,
# or when an Anthropic call fails (fallback so the loop never blocks).
STUB_SCORE=7
# Chain identifier used for DB rows. Must match an id seeded in the `chains` table.
CHAIN_ID=solana-devnet

# --- Anthropic (Claude) ---
# Leave blank to disable LLM scoring (relayer falls back to STUB_SCORE).
# Get a key at https://console.anthropic.com/settings/keys.
ANTHROPIC_API_KEY=
# Default: Sonnet 4.5 (cheap, ~$0.03 per PR). Switch to claude-opus-4-5-20251014
# once Founder Inc credits arrive — same code path, just a model swap.
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# --- GitHub (optional) ---
# Personal access token for fetching PR diffs. Without it: 60 req/hr from your
# IP, public repos only. With it: 5000 req/hr + private repos.
# Create at https://github.com/settings/tokens (classic) — needs `repo` scope
# for private, no scope needed for public.
GITHUB_TOKEN=

# --- Supabase / Postgres ---
# Supabase project URL (e.g. https://qqawdevywetmqjmiiszj.supabase.co).
SUPABASE_URL=
# service_role key — bypasses RLS, backend only, NEVER expose to frontend.
SUPABASE_SERVICE_ROLE_KEY=
# Postgres connection string (from Supabase: Project Settings > Database > URI).
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=

# --- GenLayer (BountyJudge second opinion, GHB-58/59) ---
# Leave BOUNTY_JUDGE_CONTRACT or GENLAYER_PRIVATE_KEY blank to disable.
GENLAYER_RPC=https://studio.genlayer.com/api
BOUNTY_JUDGE_CONTRACT=
GENLAYER_PRIVATE_KEY=
# Wall-clock cap for studionet consensus polling (seconds). Default 300.
GENLAYER_POLL_TIMEOUT_S=300

# --- Fly.io sandbox (GHB-70) ---
# Leave FLY_API_TOKEN or FLY_SANDBOX_APP blank to disable sandbox spawn.
# When disabled, the submission handler falls back to Opus-only evaluation
# (no test execution, GHB-73 fallback path).
#
# Token: `flyctl auth token` after login. Scope it to the sandbox app.
FLY_API_TOKEN=
# App name that hosts the ephemeral machines. Create with:
#   flyctl apps create ghbounty-sandbox
FLY_SANDBOX_APP=ghbounty-sandbox
# Image reference. Build + push with:
#   cd relayer/sandbox-image && docker build --platform linux/amd64 \
#     -t registry.fly.io/ghbounty-sandbox:v1 . && docker push registry.fly.io/ghbounty-sandbox:v1
FLY_SANDBOX_IMAGE=registry.fly.io/ghbounty-sandbox:v1
# Region for spawn. iad (Ashburn) is cheapest US, ord (Chicago) is similar.
FLY_SANDBOX_REGION=iad
# Per-run wall-clock cap (seconds). Architecture doc spec is 5 min.
FLY_SANDBOX_TIMEOUT_S=300
# Guest sizing. Architecture doc spec is 2 CPU / 2 GB.
FLY_SANDBOX_CPUS=2
FLY_SANDBOX_MEMORY_MB=2048
