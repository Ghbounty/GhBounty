# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — NEVER commit secrets.

# --- Supabase ---
# Project URL (e.g. https://kzltawaqgiwoyxxcdofm.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Anon / publishable key (safe to expose in browser, respects RLS).
# Find it in: Supabase Dashboard > Project Settings > API > anon / public
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Toggle real Supabase queries (1) vs in-memory mocks (0).
# Note: even with =0, the middleware/proxy still instantiates the client,
# so the URL + key above are required regardless.
NEXT_PUBLIC_USE_SUPABASE=0

# --- Privy (wallet auth, GHB-75 + GHB-165) ---
# Privy app ID. Public — safe to expose in the browser bundle.
# Find it in: Privy Dashboard > Apps > <your app> > App ID
NEXT_PUBLIC_PRIVY_APP_ID=

# Toggle Privy as the auth provider (takes precedence over Supabase email/pass).
# When =1, the browser uses the /api/auth/privy-bridge route to exchange the
# Privy JWT for a Supabase-compatible HS256 token (signed below). RLS policies
# match `auth.jwt() ->> 'sub'` against `profiles.user_id` (the Privy DID).
NEXT_PUBLIC_USE_PRIVY=0

# --- Supabase JWT secret (GHB-165, server-only!) ---
# Used by /api/auth/privy-bridge to mint HS256 JWTs that Supabase trusts.
# Find it in: Supabase Dashboard > Project Settings > API > JWT Settings
#                                > "JWT Secret" (NOT the publishable key).
# NEVER prefix this with NEXT_PUBLIC_ — leaking it lets anyone forge tokens
# for any user and bypass RLS entirely. Keep it server-side only.
SUPABASE_JWT_SECRET=

# --- Solana (GHB-80 escrow program) ---
# RPC endpoint for the bounty escrow program. Devnet is the default for
# development; switch to a paid RPC (Helius, QuickNode, etc.) for prod.
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com

# Deployed program id of `ghbounty_escrow`. Override only if you redeploy
# under a fresh keypair (e.g. on a private validator).
NEXT_PUBLIC_GHBOUNTY_PROGRAM_ID=CPZx26QXs3HjwGobr8cVAZEtF1qGzqnNbBdt7h1EwbBg

# Off-chain scorer wallet — the relayer's keypair, allowed to write scores
# onto Submission accounts. Stored on every Bounty at create time so the
# program can later enforce `submission.score` writes only from this key.
# Default `11111111111111111111111111111111` is a placeholder; replace with
# the relayer's real pubkey before mainnet.
NEXT_PUBLIC_SCORER_PUBKEY=11111111111111111111111111111111

# --- Gas Station (GHB-172..177) ---
# Public key of the gas-station wallet that sponsors user transactions.
# When this is set, the four user-initiated escrow ixs (create_bounty,
# submit_solution, resolve_bounty, cancel_bounty) route through
# /api/gas-station/sponsor and the user's Privy wallet only partial-
# signs. When unset, the legacy direct-send path runs (the user pays
# the fee themselves) — kept for local dev when no gas station is
# deployed.
#
# Devnet pubkey: paste from your team password manager. The matching
# private key (GAS_STATION_KEYPAIR_*) lives server-side only — never
# put it in this file.
NEXT_PUBLIC_GAS_STATION_PUBKEY=

# Chain id sent in the sponsor request body. Defaults to solana-devnet
# when unset. Flip to solana-mainnet once the mainnet keypair + Vercel
# env are wired (see docs/gas-station.md "Mainnet checklist").
NEXT_PUBLIC_GAS_STATION_CHAIN_ID=solana-devnet

# --- Review fee treasury ---
# Public key of the treasury wallet that receives the upfront review fee
# bundled with create_bounty. When unset, the review-fee feature is
# disabled (legacy/local-dev mode — bounty creation skips the fee
# transfer). The matching keypair (TREASURY_KEYPAIR_*) lives in the
# server-side .env file, never here.
NEXT_PUBLIC_TREASURY_PUBKEY=

# --- Server-side: Supabase service role + treasury keypair ---
# These are NOT NEXT_PUBLIC_ on purpose — Next.js refuses to ship them
# to the client bundle. Required by the /api/cancel-refund route to
# bypass RLS on the audit table and to sign treasury → creator transfers.
# In Vercel set them in the Production + Preview env scope.
#   SUPABASE_SERVICE_ROLE_KEY (mirror of relayer/.env)
#   TREASURY_KEYPAIR_PATH | TREASURY_KEYPAIR_JSON

# --- Auth bypass (dev only) ---
# Inject a fake user so /app/* renders without going through real auth.
# Useful for testing the data layer in isolation. NEVER enable in prod.
# To switch role: localStorage.setItem("bypassRole", "dev"); reload.
NEXT_PUBLIC_AUTH_BYPASS=0
